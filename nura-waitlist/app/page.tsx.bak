    label: "Energia",
    desc: "Vitalità naturale, tutto il giorno",
    left: "67%",
    top: "31%",
    side: "right" as const,
  },
  {
    id: "cuore",
    label: "Cuore",
    desc: "Protezione cardiovascolare avanzata",
